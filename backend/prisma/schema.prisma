generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  manager
  framer
}

enum WorkBenchSpecialty {
  standard
  museum
  shadow_box
  canvas
  specialty
}

enum WorkBenchStatus {
  available
  in_use
  cleaning
  maintenance
  closed
}

enum OrderStatus {
  recorded
  verified
  disputed
}

enum OrderType {
  standard_frame
  museum_grade
  shadow_box
  canvas_stretch
  rush
}

enum EquipmentPriority {
  low
  medium
  high
  urgent
}

enum EquipmentStatus {
  open
  in_progress
  completed
  cancelled
}

enum ChecklistCategory {
  glass_check
  corner_joint
  mat_alignment
  dust_cover
  wire_hanger
  other
}

enum ChecklistStatus {
  scheduled
  in_progress
  completed
  overdue
}

enum PricingCategory {
  standard_frame
  museum_package
  rush_service
  custom_mat
  bulk_order
  other
}

enum PricingTierStatus {
  active
  upcoming
  archived
}

enum MouldingOrderStatus {
  pending
  in_progress
  completed
  delivered
}

model FramingShop {
  id               String   @id @default(uuid())
  name             String
  phone            String?
  address          String?
  city             String?
  state            String?
  zipCode          String?  @map("zip_code")
  totalWorkBenches Int      @default(6) @map("total_work_benches")
  timezone         String   @default("America/Chicago")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  users                User[]
  workBenches          WorkBench[]
  framingOrders        FramingOrder[]
  equipmentMaintenance EquipmentMaintenance[]
  qualityChecklists    QualityChecklist[]
  pricingTiers         PricingTier[]
  mouldingOrders       MouldingOrder[]

  @@map("framing_shops")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  role          UserRole @default(owner)
  framingShopId String   @map("framing_shop_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  framingShop FramingShop @relation(fields: [framingShopId], references: [id], onDelete: Cascade)

  @@map("users")
}

model WorkBench {
  id            String             @id @default(uuid())
  framingShopId String             @map("framing_shop_id")
  name          String
  zone          String
  specialty     WorkBenchSpecialty @default(standard)
  machineModel  String?            @map("machine_model")
  status        WorkBenchStatus    @default(available)
  notes         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  framingShop          FramingShop            @relation(fields: [framingShopId], references: [id], onDelete: Cascade)
  framingOrders        FramingOrder[]
  equipmentMaintenance EquipmentMaintenance[]

  @@unique([framingShopId, name])
  @@index([framingShopId, status])
  @@map("work_benches")
}

model FramingOrder {
  id            String      @id @default(uuid())
  framingShopId String      @map("framing_shop_id")
  workBenchId   String      @map("work_bench_id")
  dueAt         DateTime    @map("due_at")
  orderType     OrderType   @default(standard_frame) @map("order_type")
  cashAmount    Float       @default(0) @map("cash_amount")
  cardAmount    Float       @default(0) @map("card_amount")
  itemCount     Int         @default(1) @map("item_count")
  rushFee       Float       @default(0) @map("rush_fee")
  status        OrderStatus @default(recorded)
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  framingShop FramingShop @relation(fields: [framingShopId], references: [id], onDelete: Cascade)
  workBench   WorkBench   @relation(fields: [workBenchId], references: [id], onDelete: Cascade)

  @@index([framingShopId, dueAt])
  @@index([framingShopId, status])
  @@map("framing_orders")
}

model EquipmentMaintenance {
  id            String            @id @default(uuid())
  framingShopId String            @map("framing_shop_id")
  workBenchId   String            @map("work_bench_id")
  title         String
  description   String?
  reportedAt    DateTime          @map("reported_at")
  completedAt   DateTime?         @map("completed_at")
  priority      EquipmentPriority @default(medium)
  status        EquipmentStatus   @default(open)
  cost          Float?
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  framingShop FramingShop @relation(fields: [framingShopId], references: [id], onDelete: Cascade)
  workBench   WorkBench   @relation(fields: [workBenchId], references: [id], onDelete: Cascade)

  @@index([framingShopId, status])
  @@index([framingShopId, priority])
  @@map("equipment_maintenance")
}

model QualityChecklist {
  id            String            @id @default(uuid())
  framingShopId String            @map("framing_shop_id")
  title         String
  description   String?
  category      ChecklistCategory @default(other)
  zone          String?
  scheduledAt   DateTime          @map("scheduled_at")
  status        ChecklistStatus   @default(scheduled)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  framingShop FramingShop @relation(fields: [framingShopId], references: [id], onDelete: Cascade)

  @@index([framingShopId, scheduledAt])
  @@map("quality_checklists")
}

model PricingTier {
  id              String            @id @default(uuid())
  framingShopId   String            @map("framing_shop_id")
  title           String
  pricingCategory PricingCategory   @default(standard_frame) @map("pricing_category")
  status          PricingTierStatus @default(active)
  basePrice       Float             @map("base_price")
  priceMultiplier Float             @default(1.0) @map("price_multiplier")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  framingShop FramingShop @relation(fields: [framingShopId], references: [id], onDelete: Cascade)

  @@index([framingShopId, pricingCategory])
  @@map("pricing_tiers")
}

model MouldingOrder {
  id              String              @id @default(uuid())
  framingShopId   String              @map("framing_shop_id")
  customerName    String              @map("customer_name")
  mouldingProfile String              @map("moulding_profile")
  supplierName    String?             @map("supplier_name")
  status          MouldingOrderStatus @default(pending)
  price           Float               @default(0)
  notes           String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  framingShop FramingShop @relation(fields: [framingShopId], references: [id], onDelete: Cascade)

  @@index([framingShopId, status])
  @@map("moulding_orders")
}
